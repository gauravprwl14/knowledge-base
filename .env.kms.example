# =============================================================================
# KMS Environment Variables
# =============================================================================
# Copy to .env.kms and fill in values.
# Never commit .env.kms to git.
#
# Tier legend:
#   [REQUIRED]  Must be set before starting services
#   [DEFAULT]   Has safe default — override for production
#   [OPTIONAL]  Feature-gated — only needed if the feature is enabled
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=kms                             # [DEFAULT]
POSTGRES_PASSWORD=kms                         # [REQUIRED in production]
POSTGRES_DB=kms                               # [DEFAULT]

# ── Redis ────────────────────────────────────────────────────────────────────
# No credentials needed in dev. Add AUTH for production.

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest                           # [DEFAULT]
RABBITMQ_PASS=guest                           # [REQUIRED in production]

# ── Auth (kms-api) ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production            # [REQUIRED] min 32 chars
JWT_REFRESH_SECRET=change-me-refresh-secret   # [REQUIRED] min 32 chars
JWT_EXPIRES_IN=15m                            # [DEFAULT]
JWT_REFRESH_EXPIRES_IN=7d                     # [DEFAULT]

# ── Google Drive Integration ─────────────────────────────────────────────────
# [OPTIONAL] Required when features.googleDrive.enabled=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Transcription Providers ──────────────────────────────────────────────────
# [OPTIONAL] Used by voice-app. At least one provider recommended.
GROQ_API_KEY=
DEEPGRAM_API_KEY=

# ── Translation / LLM ────────────────────────────────────────────────────────
# [OPTIONAL] Used for translation and RAG when llm.provider=openrouter
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ── Object Storage (MinIO) ───────────────────────────────────────────────────
MINIO_USER=minioadmin                         # [DEFAULT]
MINIO_PASSWORD=minioadmin                     # [REQUIRED in production]

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin                            # [DEFAULT]
GRAFANA_PASSWORD=admin                        # [REQUIRED in production]

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=kmspassword                    # [DEFAULT] Required when graph.enabled=true

# ── KMS Config Path ──────────────────────────────────────────────────────────
KMS_CONFIG_PATH=./.kms/config.json            # [DEFAULT]
