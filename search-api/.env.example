# Server
PORT=8001
NODE_ENV=development

# PostgreSQL — used for BM25 full-text search
DATABASE_URL=postgresql://kms:kms@localhost:5432/kms

# Qdrant — used for semantic vector search
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kms_chunks

# Mock flags — set to true to skip real DB/Qdrant calls (dev/test)
MOCK_BM25=true
MOCK_SEMANTIC=true

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
