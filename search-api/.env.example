# search-api environment variables
NODE_ENV=development
PORT=8001
HOST=0.0.0.0
LOG_LEVEL=info
API_PREFIX=api/v1

# PostgreSQL (same database as kms-api)
DATABASE_URL=postgresql://kms_user:kms_password@localhost:5432/kms_db

# Qdrant vector database
QDRANT_URL=http://localhost:6333

# embed-worker (BGE-M3 embedding endpoint)
EMBED_WORKER_URL=http://embed-worker:8010

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# OpenTelemetry
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
APP_NAME=search-api
