import { NextRequest, NextResponse } from 'next/server';

export async function GET(
  request: NextRequest,
  { params }: { params: Promise<{ id: string }> }
) {
  const apiKey = request.headers.get('X-API-Key');

  if (!apiKey) {
    return NextResponse.json(
      { error: 'API key is required' },
      { status: 401 }
    );
  }

  try {
    const format = request.nextUrl.searchParams.get('format') || 'txt';
    const backendUrl = process.env.NEXT_PUBLIC_API_URL || 'http://backend:8000';
    const id = params.id;
    
    const response = await fetch(
      `${backendUrl}/api/v1/transcriptions/${id}/download?format=${format}`,
      {
        headers: {
          'X-API-Key': apiKey,
        },
      }
    );

    if (!response.ok) {
      return NextResponse.json(
        { error: 'Failed to download transcription' },
        { status: response.status }
      );
    }

    const buffer = await response.arrayBuffer();
    const headers = new Headers(response.headers);
    headers.set('Content-Disposition', `attachment; filename="transcription.${format}"`);
    
    return new Response(buffer, {
      headers,
    });
  } catch (error) {
    console.error('API route error:', error);
    return NextResponse.json(
      { error: 'Failed to download transcription' },
      { status: 500 }
    );
  }
}
