{
  "$schema": "https://json.schemastore.org/swcrc",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@search/*": ["src/search/*"],
      "@common/*": ["src/common/*"]
    },
    "target": "es2022",
    "keepClassNames": true
  },
  "module": { "type": "commonjs" },
  "sourceMaps": true
}
