{
  "name": "@kb/search-api",
  "version": "1.0.0",
  "description": "KMS Search API — hybrid keyword + semantic search",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "type:check": "tsc --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --testPathPattern=src"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@opentelemetry/api": "latest",
    "@opentelemetry/auto-instrumentations-node": "latest",
    "@opentelemetry/exporter-trace-otlp-grpc": "latest",
    "@opentelemetry/sdk-node": "latest",
    "@opentelemetry/semantic-conventions": "latest",
    "@prisma/client": "^7.0.0",
    "ioredis": "^5.4.0",
    "pino": "^9.6.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.2",
    "zod": "^3.24.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.13.0",
    "nestjs-pino": "^4.3.0",
    "@nestjs/cache-manager": "^3.0.0",
    "cache-manager": "^5.7.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.7.0",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.11",
    "@types/pg": "^8.11.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "prisma": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.8.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": ["@swc/jest", {
        "jsc": {
          "parser": { "syntax": "typescript", "decorators": true },
          "transform": { "legacyDecorator": true, "decoratorMetadata": true },
          "keepClassNames": true,
          "target": "es2022"
        },
        "module": { "type": "commonjs" }
      }]
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.spec.ts",
      "!src/main.ts"
    ],
    "coverageDirectory": "./coverage",
    "coverageThreshold": {
      "global": { "branches": 70, "functions": 70, "lines": 80, "statements": 80 }
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@search/(.*)$": "<rootDir>/src/search/$1",
      "^@common/(.*)$": "<rootDir>/src/common/$1"
    }
  },
  "engines": { "node": ">=22.0.0" }
}
