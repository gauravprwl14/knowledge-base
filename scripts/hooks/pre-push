#!/bin/sh
# scripts/hooks/pre-push — Validates PRD quality before git push.
# Install: cp scripts/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# Or run:  make setup-hooks
#
# BLOCKING_MODE controls whether failures actually block the push.
# Set to true after the first sprint.
BLOCKING_MODE=false

# ── detect PRD files in this push (reads stdin per git pre-push spec) ─────────
# stdin format: <local-ref> <local-sha1> <remote-ref> <remote-sha1>
CHANGED=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch — diff against empty tree object
    FILES=$(git diff --name-only 4b825dc642cb6eb9a060e54bf8d69288fbee4904 "$local_sha" 2>/dev/null | grep '^docs/prd/' || true)
  else
    FILES=$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null | grep '^docs/prd/' || true)
  fi
  CHANGED="${CHANGED}${FILES}"
done

[ -z "$CHANGED" ] && exit 0

# ── checklist runner ──────────────────────────────────────────────────────────
BLOCK=0

check_item() {
  local label="$1"
  local pattern="$2"
  local file="$3"
  if grep -qiE "${pattern}" "${file}" 2>/dev/null; then
    return 0  # PASS
  else
    echo "  FAIL — ${label}"
    return 1
  fi
}

echo "$CHANGED" | while IFS= read -r prd_file; do
  [ -z "$prd_file" ] && continue
  [ -f "$prd_file" ] || continue

  echo ""
  echo "PRD QUALITY CHECK: ${prd_file}"
  echo "──────────────────────────────────────────────────────────"

  fail_count=0

  check_item \
    "User stories (As a [role], I want [action], so that [outcome])" \
    "As a .* I want .* so that" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  check_item \
    "Happy path flows documented" \
    "happy.path|success.flow|## Flow|## Flows" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  check_item \
    "Error flows documented" \
    "error.flow|failure.case|## Error|## Errors" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  check_item \
    "Edge cases listed" \
    "edge.case|empty.state|concurrent|## Edge" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  check_item \
    "Integration contracts present" \
    "API call|endpoint|payload|## Integration" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  check_item \
    "KB error codes referenced (KB[A-Z]{3}[0-9]{4})" \
    "KB[A-Z][A-Z][A-Z][0-9]" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  check_item \
    "Test scenarios listed" \
    "test.scenario|## Test|test case" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  check_item \
    "Non-functional requirements (latency / SLO / rate-limit)" \
    "latency|SLO|rate.limit|## Non-functional" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  check_item \
    "Out of scope stated" \
    "[Oo]ut.of.[Ss]cope|## Out of [Ss]cope" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  check_item \
    "Sequence diagram referenced" \
    "sequence.diagram|mermaid|sequence-diagrams" \
    "${prd_file}" || fail_count=$(( fail_count + 1 ))

  if [ "${fail_count}" -gt 2 ]; then
    echo ""
    echo "  WARNING: ${prd_file} failed ${fail_count}/10 checklist items (threshold: >2)."
    if [ "${BLOCKING_MODE}" = "true" ]; then
      echo "  Push BLOCKED. Fix the PRD or set BLOCKING_MODE=false to warn-only."
      BLOCK=1
    else
      echo "  Push allowed (BLOCKING_MODE=false). Fix before next sprint."
    fi
  else
    echo "  OK: ${fail_count}/10 items failed — within acceptable threshold."
  fi
  echo "──────────────────────────────────────────────────────────"
done

echo ""

# ── final gate ────────────────────────────────────────────────────────────────
if [ "${BLOCKING_MODE}" = "true" ] && [ "${BLOCK}" -eq 1 ]; then
  exit 1
fi

exit 0
