# Test Environment Configuration
NODE_ENV=test
APP_NAME=kms-api-test
APP_PORT=8100
APP_HOST=0.0.0.0
API_PREFIX=api
API_VERSION=v1
LOG_LEVEL=error

# Test Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/kms_test?schema=public

# Test Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=1

# Test Queue
QUEUE_HOST=localhost
QUEUE_PORT=5673
QUEUE_USER=guest
QUEUE_PASSWORD=guest

# Test Auth
JWT_ACCESS_SECRET=test-jwt-access-secret-for-testing-only
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=test-jwt-refresh-secret-for-testing-only
JWT_REFRESH_EXPIRATION=7d
API_KEY_ENCRYPTION_SECRET=test-api-key-encryption-secret-32

# Test OpenTelemetry (disabled)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=kms-api-test
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Test Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=1000

# Test CORS
CORS_ORIGINS=http://localhost:3000
