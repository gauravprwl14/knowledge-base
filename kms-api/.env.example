# =============================================================================
# KMS API Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=kms-api
APP_PORT=8000
APP_HOST=0.0.0.0
API_PREFIX=api
API_VERSION=v1

# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kms_dev?schema=public

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Queue (Bull/RabbitMQ)
# -----------------------------------------------------------------------------
QUEUE_HOST=localhost
QUEUE_PORT=5672
QUEUE_USER=guest
QUEUE_PASSWORD=guest

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_REFRESH_EXPIRATION=7d

# API Key encryption
API_KEY_ENCRYPTION_SECRET=your-api-key-encryption-secret-32chars

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback

# -----------------------------------------------------------------------------
# OpenTelemetry
# -----------------------------------------------------------------------------
OTEL_ENABLED=true
OTEL_SERVICE_NAME=kms-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Jaeger (if not using OTLP)
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
VOICE_APP_URL=http://localhost:8001
SEARCH_API_URL=http://localhost:8002
